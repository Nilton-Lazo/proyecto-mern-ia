# MongoDB — ajusta según tu instalación local
# Con autenticación (usuario dev:dev):
MONGODB_URI=mongodb://dev:dev@127.0.0.1:27017/tutor_virtual?authSource=admin
# Sin autenticación (Mongo local simple):
# MONGODB_URI=mongodb://127.0.0.1:27017/tutor-lectura

PORT=3000
JWT_SECRET=cambiar-este-secreto-en-produccion

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:8b

# --- Automatización n8n (capa externa, no reemplaza backend) ---
BACKEND_BASE_URL=http://localhost:3000
N8N_BASE_URL=http://localhost:5678
N8N_TEST_WEBHOOK_URL=http://localhost:5678/webhook-test/test-n8n
N8N_INTERNAL_API_KEY=change_me
N8N_WEBHOOK_TIMEOUT_MS=15000
N8N_GENERATE_QUESTIONS_WEBHOOK_URL=
N8N_DETECT_BIASES_WEBHOOK_URL=
N8N_ACTIVITY_ASSIGNED_WEBHOOK_URL=http://localhost:5678/webhook-test/activity-assigned
N8N_READING_REMINDER_WEBHOOK_URL=

# --- Correo (opcional; los workflows n8n pueden usar SMTP propio) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
