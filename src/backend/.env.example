# MongoDB (local Docker: mongodb://mongo:27017/tutor-lectura)
MONGODB_URI=mongodb://127.0.0.1:27017/tutor-lectura

# Puerto del API Express
PORT=3000

# Secreto para firmar/verificar JWT (cambiar en producción)
JWT_SECRET=cambiar-este-secreto

# Ollama (generación de preguntas, feedback y sesgos)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:8b
